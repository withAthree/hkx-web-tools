{
  "compilerOptions": {
    "target": "ESNext",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": false,
    "noEmit": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["src/*"],
      "hkx-eslint-config": ["./packages/lint/eslint-config"]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "**/fixtures/**/*.*",
    "**/_fixtures/**/*.*",
  ]
}